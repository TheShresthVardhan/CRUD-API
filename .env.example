# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# Postgres credentials (used by the `db` service in docker-compose.yml
# to initialize the database on first boot)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Full connection string the API uses to reach Postgres.
# Inside Docker, host is the compose service name ("db"), not localhost.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=
